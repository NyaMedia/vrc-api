  },
  "components": {
    "schemas": {
      "Movie": {
        "type": "object",
        "required": [
          "title",
          "vrcurl"
        ],
        "properties": {
          "title": {
            "type": "string",
            "description": "Movie title",
            "example": "Spider-Man"
          },
          "releaseYear": {
            "type": "string",
            "description": "Year the movie was released",
            "example": "2002"
          },
          "overview": {
            "type": "string",
            "description": "Movie overview/synopsis (may contain spoilers)",
            "example": "After being bitten by a genetically altered spider at Oscorp, nerdy but endearing high school student Peter Parker is endowed with amazing powers to become the superhero known as Spider-Man."
          },
          "rating": {
            "type": "string",
            "description": "Movie rating out of 10",
            "example": "7.3"
          },
          "vrcurl": {
            "type": "integer",
            "description": "Index of VRCUrl that will redirect to the movie file, or a 404 video if not found",
            "minimum": 0,
            "maximum": 9999,
            "example": 1234
          }
        }
      },
      "Anime": {
        "type": "object",
        "required": [
          "title",
          "episodesUrl"
        ],
        "properties": {
          "title": {
            "type": "string",
            "description": "Anime title"
          },
          "releaseYear": {
            "type": "string",
            "description": "Year the anime was released"
          },
          "overview": {
            "type": "string",
            "description": "Anime overview/synopsis"
          },
          "rating": {
            "type": "string",
            "description": "Anime rating out of 10"
          },
          "episodesUrl": {
            "type": "integer",
            "description": "VRCUrl index for episodes",
            "minimum": 0,
            "maximum": 9999
          }
        }
      },
      "Season": {
        "type": "object",
        "properties": {
          "seasonName": {
            "type": "string"
          },
          "vrcurl": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9999
          }
        }
      },
      "Show": {
        "type": "object",
        "required": [
          "title"
        ],
        "properties": {
          "title": {
            "type": "string",
            "description": "Show title"
          },
          "releaseYear": {
            "type": "string",
            "description": "Year the show was released"
          },
          "overview": {
            "type": "string",
            "description": "Show overview/synopsis"
          },
          "rating": {
            "type": "string",
            "description": "Show rating out of 10"
          },
          "seasons": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Season"
            }
          }
        }
      }
    },
    "parameters": {
      "PoolParameter": {
        "name": "pool",
        "in": "query",
        "required": true,
        "description": "Unique ID for your VRCUrl pool",
        "schema": {
          "type": "string",
          "pattern": "^[a-z-_]+\\d*$"
        }
      }
    }
  }
}
